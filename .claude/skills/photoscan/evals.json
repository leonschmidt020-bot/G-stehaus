{
  "evals": [
    {
      "id": "simple-landing-page",
      "prompt": "Ich zeige dir einen Screenshot einer einfachen Landing Page. Analysiere das Design (Farben, Fonts, Layout) und erstelle dann den vollständigen HTML/CSS Code, um sie nachzubauen.",
